generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  passwordHash    String?
  name            String?
  role            UserRole         @default(EDITOR)
  status          UserStatus       @default(PENDING_APPROVAL)
  approvedAt      DateTime?
  approvedById    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  lastLoginAt     DateTime?
  approvalActions ApprovalAction[]
  auditLogs       AuditLog[]
  authoredContent Content[]        @relation("ContentAuthor")
  reviewedContent Content[]        @relation("ContentReviewer")
  otpCodes        OtpCode[]
  revisions       Revision[]
  sessions        Session[]
  approvedBy      User?            @relation("ApprovedUsers", fields: [approvedById], references: [id])
  approvedUsers   User[]           @relation("ApprovedUsers")

  @@index([email])
  @@index([status])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model OtpCode {
  id         String     @id @default(cuid())
  userId     String?
  email      String
  code       String
  purpose    OtpPurpose
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime   @default(now())
  user       User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, purpose])
  @@index([code])
}

model PublicUser {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String?
  avatarUrl        String?
  googleId         String            @unique
  phoneNumber      String?
  createdAt        DateTime          @default(now())
  lastLoginAt      DateTime?
  eventBookings    EventBooking[]
  onDemandRequests OnDemandRequest[]
  ticketPurchases  TicketPurchase[]

  @@index([googleId])
}

model Content {
  id                 String              @id @default(cuid())
  type               ContentType
  status             ContentStatus       @default(DRAFT)
  slug               String
  title              String
  subtitle           String?
  excerpt            String?             @db.Text
  body               String?             @db.Text
  locale             String              @default("en")
  parentId           String?
  metadata           Json?
  authorId           String
  reviewerId         String?
  publishedAt        DateTime?
  scheduledFor       DateTime?
  unpublishAt        DateTime?
  startsAt           DateTime?
  endsAt             DateTime?
  venue              String?
  venueAddress       String?
  capacity           Int?
  ticketPrice        Decimal?            @db.Decimal(12, 2)
  price              Decimal?            @db.Decimal(12, 2)
  currency           String?             @default("USD")
  year               Int?
  make               String?
  model              String?
  category           String?
  location           String?
  projectStage       String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  approvalActions    ApprovalAction[]
  author             User                @relation("ContentAuthor", fields: [authorId], references: [id])
  parent             Content?            @relation("ContentTranslations", fields: [parentId], references: [id])
  translations       Content[]           @relation("ContentTranslations")
  reviewer           User?               @relation("ContentReviewer", fields: [reviewerId], references: [id])
  media              Media[]
  revisions          Revision[]
  shukshutaSubEvents ShukshutaSubEvent[] @relation("ParentEvent")
  parentEvent        ShukshutaSubEvent?  @relation("SubEvent")

  @@unique([slug, locale])
  @@index([type, status])
  @@index([slug, locale])
  @@index([parentId])
  @@index([scheduledFor])
  @@index([unpublishAt])
  @@index([locale])
}

model ShukshutaSubEvent {
  id            String  @id @default(cuid())
  parentEventId String
  subEventId    String  @unique
  displayOrder  Int     @default(0)
  parentEvent   Content @relation("ParentEvent", fields: [parentEventId], references: [id], onDelete: Cascade)
  subEvent      Content @relation("SubEvent", fields: [subEventId], references: [id], onDelete: Cascade)

  @@index([parentEventId])
}

model ApprovalAction {
  id           String             @id @default(cuid())
  contentId    String
  userId       String
  action       ApprovalActionType
  comment      String?             @db.Text
  diffSnapshot Json?
  createdAt    DateTime           @default(now())
  content      Content            @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id])

  @@index([contentId])
  @@index([userId])
}

model Revision {
  id         String   @id @default(cuid())
  contentId  String
  userId     String
  snapshot   Json
  changeNote String?             @db.Text
  createdAt  DateTime @default(now())
  content    Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@index([contentId, createdAt])
}

model Media {
  id           String    @id @default(cuid())
  filename     String
  mimeType     String
  type         MediaType @default(IMAGE)
  size         Int
  width        Int?
  height       Int?
  r2Key        String    @unique
  publicUrl    String
  thumbnailUrl String?
  blurhash     String?
  altText      String?
  contentId    String?
  uploadedById String?
  createdAt    DateTime  @default(now())
  content      Content?  @relation(fields: [contentId], references: [id])

  @@index([contentId])
  @@index([type])
}

model Partner {
  id           String      @id @default(cuid())
  name         String
  tier         PartnerTier
  logoUrl      String?
  websiteUrl   String?
  description  String?             @db.Text
  isFeatured   Boolean     @default(false)
  displayOrder Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([tier])
  @@index([isFeatured])
}

model Inquiry {
  id           String          @id @default(cuid())
  division     InquiryDivision
  status       InquiryStatus   @default(NEW)
  name         String
  organization String?
  email        String
  phone        String?
  message      String              @db.Text
  metadata     Json?
  ipAddress    String?
  userAgent    String?
  assignedToId String?
  resolvedAt   DateTime?
  createdAt    DateTime        @default(now())

  @@index([division, status])
  @@index([createdAt])
}

model EventBooking {
  id           String        @id @default(cuid())
  eventId      String
  publicUserId String
  status       BookingStatus @default(PENDING)
  partySize    Int           @default(1)
  phoneNumber  String
  notes        String?             @db.Text
  createdAt    DateTime      @default(now())
  publicUser   PublicUser    @relation(fields: [publicUserId], references: [id])

  @@index([eventId])
  @@index([publicUserId])
  @@index([status])
}

model TicketPurchase {
  id            String         @id @default(cuid())
  eventId       String
  publicUserId  String
  ticketType    String
  quantity      Int
  unitPrice     Decimal        @db.Decimal(12, 2)
  totalPrice    Decimal        @db.Decimal(12, 2)
  currency      String         @default("USD")
  paymentRef    String?
  serialNumber  String         @unique
  passIssuedAt  DateTime?
  passExpiresAt DateTime?
  status        BookingStatus  @default(PENDING)
  phoneNumber   String
  createdAt     DateTime       @default(now())
  publicUser    PublicUser     @relation(fields: [publicUserId], references: [id])
  checkout      CheckoutSession?

  @@index([eventId])
  @@index([publicUserId])
  @@index([serialNumber])
  @@index([status])
}

model OnDemandRequest {
  id           String        @id @default(cuid())
  publicUserId String
  projectType  String
  location     String
  budget       String?
  timeline     String?
  description  String              @db.Text
  contactPhone String
  status       BookingStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  publicUser   PublicUser    @relation(fields: [publicUserId], references: [id])

  @@index([publicUserId])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([entityType, entityId])
}

model TeamMember {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  role          String
  bio           String?             @db.Text
  photoUrl      String?
  photoBlurhash String?
  email         String?
  linkedinUrl   String?
  displayOrder  Int      @default(0)
  isLeadership  Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isLeadership])
  @@index([displayOrder])
}

model GlossaryTerm {
  id           String   @id @default(cuid())
  term         String   @unique
  translations Json
  context      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum UserRole {
  ADMIN
  EDITOR
}

enum UserStatus {
  PENDING_APPROVAL
  ACTIVE
  DEACTIVATED
}

enum OtpPurpose {
  REGISTRATION
  PASSWORD_RESET
  EMAIL_CHANGE
}

enum ContentType {
  EVENT
  VEHICLE
  REAL_ESTATE_PROJECT
  GALLERY_ITEM
  PARTNER
  PAGE
  SHUKSHUTA_EVENT
}

enum ContentStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  PUBLISHED
  REJECTED
  ARCHIVED
  SOLD
  ENDED
}

enum ApprovalActionType {
  SUBMIT
  APPROVE
  REJECT
  REQUEST_CHANGES
  PUBLISH
  UNPUBLISH
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum PartnerTier {
  STRATEGIC
  CULTURAL
  MEDIA
}

enum InquiryDivision {
  EVENTS
  TRADING
  REAL_ESTATE
  GENERAL
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  SPAM
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  ATTENDED
}

// =====================================================
// Chapter 1 — Offline QR Gate Pass Microservice schema
// =====================================================

enum CheckoutStatus {
  INITIATED
  PENDING_PAYMENT
  PAID
  TICKET_ISSUED
  EXPIRED
  FAILED
}

enum PaymentProvider {
  STRIPE
  BOA
  TELEBIRR
  CBEBIRR
  CHAPA
  SIMULATED
}

enum DeviceStatus {
  PROVISIONED
  ACTIVE
  DEACTIVATED
}

model CheckoutSession {
  id                String           @id @default(cuid())
  userId            String
  publicUserId      String?
  ticketTypeId      String
  ticketTypeLabel   String           @default("GENERAL")
  eventId           String
  eventSlug         String?
  quantity          Int              @default(1)
  unitAmount        Decimal          @db.Decimal(12, 2)
  totalAmount       Decimal          @db.Decimal(12, 2)
  currency          String           @default("USD")
  paymentProvider   PaymentProvider
  providerSessionId String?          @unique
  providerPayload   Json?
  returnUrl         String?
  customerEmail     String?
  customerPhone     String?
  status            CheckoutStatus   @default(INITIATED)
  expiresAt         DateTime
  paidAt            DateTime?
  issuedAt          DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  ticketPurchaseId  String?          @unique
  ticketPurchase    TicketPurchase?  @relation(fields: [ticketPurchaseId], references: [id])

  @@index([userId])
  @@index([status, expiresAt])
  @@index([paymentProvider])
  @@index([eventId])
}

model ProcessedWebhook {
  id                    String          @id @default(cuid())
  provider              PaymentProvider
  providerTransactionId String
  associatedOrderId     String?
  rawPayload            Json
  processedAt           DateTime        @default(now())

  @@unique([provider, providerTransactionId])
  @@index([processedAt])
  @@index([associatedOrderId])
}

model GateDevice {
  id               String       @id @default(cuid())
  hardwareId       String       @unique
  name             String
  venue            String?
  apiKeyHash       String       @unique
  apiKeyPrefix     String
  status           DeviceStatus @default(PROVISIONED)
  publicKeyFingerprint String?
  lastSeenAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  scans            GateScan[]
  auditFlags       GateAudit[]

  @@index([status])
  @@index([venue])
}

model GateScan {
  id              String     @id @default(cuid())
  deviceId        String
  serialNumber    String
  ticketId        String?
  scannedAt       DateTime
  payloadSnapshot Json?
  syncStatus      Boolean    @default(false)
  syncedAt        DateTime?
  device          GateDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, serialNumber])
  @@index([serialNumber])
  @@index([syncStatus])
  @@index([scannedAt])
}

model GateAudit {
  id              String     @id @default(cuid())
  deviceId        String
  serialNumber    String
  conflictWithId  String?
  reason          String
  metadata        Json?
  createdAt       DateTime   @default(now())
  device          GateDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([serialNumber])
  @@index([reason])
}
