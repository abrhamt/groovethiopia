# =====================================================
# Staging / preview environment — groovethiopia.livejamgames.com
# Copy this file to apps/backend/.env.staging on the server and fill in
# real values. Never commit the real file.
# =====================================================

# --- Database (staging MySQL container, internal only) ---
DATABASE_URL="mysql://root:staging@staging-mysql:3306/groovethiopia_staging"

# --- Stripe (use TEST keys or leave empty for fully simulated checkout) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- Auth.js — REQUIRED, generate with `openssl rand -base64 32` ---
AUTH_SECRET="CHANGE-ME-generate-with-openssl-rand-base64-32"
AUTH_URL="https://groovethiopia.livejamgames.com"
NEXTAUTH_URL="https://groovethiopia.livejamgames.com"

# --- Google OAuth (public users) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Cloudflare R2 (use a SEPARATE staging bucket if you have one) ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="groovethiopia-media-staging"
R2_PUBLIC_URL="https://media.groovethiopia.livejamgames.com"

# --- Resend (test key is fine — staging emails go to a catch-all) ---
RESEND_API_KEY=""
EMAIL_FROM="Groovethiopia Staging <staging@livejamgames.com>"

# --- Inngest ---
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# --- Sentry (optional; point to a separate staging project if you have one) ---
SENTRY_DSN=""
SENTRY_ENVIRONMENT="staging"

# --- Google reCAPTCHA v3 ---
RECAPTCHA_SECRET_KEY=""
RECAPTCHA_SITE_KEY=""

# --- Google Translate ---
GOOGLE_TRANSLATE_API_KEY=""

# --- App URLs ---
NEXT_PUBLIC_FRONTEND_URL="https://groovethiopia.livejamgames.com"
NEXT_PUBLIC_ADMIN_URL="https://groovethiopia.livejamgames.com/admin"
CORS_ORIGIN="https://groovethiopia.livejamgames.com"

# --- Initial admin (for CLI bootstrap) ---
ADMIN_EMAIL="admin@livejamgames.com"
ADMIN_PASSWORD="ChangeMeImmediately!"
