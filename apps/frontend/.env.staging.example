# Frontend env — staging / preview (groovethiopia.livejamgames.com)
# Copy this file to apps/frontend/.env.staging on the server and fill in
# real values. Never commit the real file.

NEXT_PUBLIC_API_URL="https://groovethiopia.livejamgames.com"
NEXT_PUBLIC_SITE_URL="https://groovethiopia.livejamgames.com"

# Google OAuth (public users)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# reCAPTCHA v3
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""

# Sentry
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_ENVIRONMENT="staging"
