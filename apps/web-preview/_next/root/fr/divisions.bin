py-32 border-t border-ink-800/50\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-4xl mx-auto text-center\",\"children\":[\"$\",\"p\",null,{\"className\":\"text-2xl font-serif font-light leading-relaxed text-ink-200\",\"children\":\"Each division reinforces the others. Events fund the cultural capital. Trading builds commercial velocity. Real estate creates destinations that anchor it all.\"},\"$38\",\"$91\",1]},\"$38\",\"$90\",1]},\"$38\",\"$8f\",1]\n94:D\"$95\"\n28:[\"$\",\"html\",null,{\"lang\":\"fr\",\"className\":\"dark\",\"suppressHydrationWarning\":true,\"children\":[\"$\",\"body\",null,{\"className\":\"__variable_f367f3 __variable_81aec9 __variable_054274 font-sans bg-background text-foreground antialiased min-h-screen\",\"children\":\"$L94\"},\"$29\",\"$93\",1]},\"$29\",\"$92\",1]\n"])</script><script>self.__next_f.push([1,"94:[\"$\",\"$L97\",null,{\"locale\":\"fr\",\"now\":\"$D2026-07-10T18:34:46.630Z\",\"timeZone\":\"Africa/Addis_Ababa\",\"messages\":{\"brand\":{\"tagline\":\"Organiser le Nouvel Horizon\",\"name\":\"Groovethiopia\"},\"nav\":{\"home\":\"Accueil\",\"about\":\"À propos\",\"divisions\":\"Divisions\",\"events\":\"Le Pouls\",\"trading\":\"La Collection\",\"realEstate\":\"Le Sanctuaire\",\"gallery\":\"Galerie\",\"partners\":\"Partenaires\",\"contact\":\"Contact\"},\"home\":{\"hero\":{\"tagline\":\"Organiser le Nouvel Horizon\",\"subtitle\":\"Un écosystème curated de culture, d'artisanat et de lieu.\",\"cta\":\"Explorer\"},\"manifesto\":{\"title\":\"Notre philosophie\",\"body\":\"Nous organisons le mode de vie africain moderne — reliant le patrimoine de notre terre à l'innovation du futur.\"},\"ecosystem\":{\"title\":\"Un lieu, trois expériences\",\"subtitle\":\"Trois mondes, une vision.\",\"events\":\"Le Pouls\",\"eventsDesc\":\"Événements culturels qui font avancer la scène\",\"trading\":\"La Collection\",\"tradingDesc\":\"Patrimoine automobile et luxe moderne\",\"realEstate\":\"Le Sanctuaire\",\"realEstateDesc\":\"Destinations hôtelières de demain\"},\"featured\":{\"events\":\"Événement à la une\",\"collection\":\"La Collection\",\"sanctuary\":\"Le Sanctuaire\",\"viewAll\":\"Voir tout\"},\"cta\":{\"title\":\"Construisons l'avenir ensemble\",\"body\":\"Groovethiopia est un écosystème centré sur l'invitation.\",\"button\":\"Demander\"}},\"about\":{\"title\":\"Façonner l'avenir du style de vie et de la culture éthiopiens\",\"subtitle\":\"Groove Ethiopia Trading PLC est un conglomérat éthiopien de premier plan dédié à l'excellence dans l'hospitalité, le style de vie et le commerce stratégique. Enracinés à Addis-Abeba et profondément connectés aux marchés régionaux et internationaux, nous comblons le fossé entre un service de classe mondiale et des expériences culturelles authentiques.\\n\\nEn tant que force diversifiée, notre portefeuille englobe la production d'événements à concept élevé, des solutions d'import-export premium et le développement immobilier avant-gardiste. Nous ne nous contentons pas de participer au marché ; nous définissent le paysage en façonnant l'avenir de l'hospitalité éthiopienne moderne.\",\"partnership\":{\"title\":\"Un Partenariat de Visionnaires.\",\"body\":\"Groovethiopia est un écosystème centré sur les invitations. Nous privilégions la collaboration avec des individus, des marques et des investisseurs qui valorisent l'intersection de la culture, du luxe et du développement à long terme.\",\"inquire\":\"Demande de partenariat\",\"inquireDesc\":\"Production d'événements, architecture sonore \u0026 collaboration créative\",\"consult\":\"Demander une consultation\",\"consultDesc\":\"Approvisionnement automobile de luxe \u0026 vintage\",\"invest\":\"Explorer l'investissement\",\"investDesc\":\"Opportunités immobilières \u0026 de développement\"},\"manifesto\":{\"title\":\"Manifeste\",\"body\":\"Nous organisons le mode de vie africain moderne.\"},\"mission\":{\"title\":\"Mission\",\"body\":\"Définir le paysage de l'hospitalité éthiopienne moderne.\"},\"vision\":{\"title\":\"Vision\",\"body\":\"Un avenir où l'Éthiopie est reconnue comme un nexus de culture et de luxe.\"},\"story\":{\"title\":\"Notre histoire\",\"body\":\"Né à Addis-Abeba de la conviction que l'Afrique mérite une curation de classe mondiale.\"},\"values\":{\"title\":\"Nos valeurs\",\"list\":[{\"title\":\"Curation\",\"body\":\"Nous choisissons délibérément.\"},{\"title\":\"Artisanat\",\"body\":\"Le patrimoine rencontre la précision.\"},{\"title\":\"Pont culturel\",\"body\":\"Enraciné en Éthiopie, fluent dans le monde.\"},{\"title\":\"Vision long terme\",\"body\":\"Nous construisons pour des décennies.\"}]},\"team\":{\"title\":\"Direction\",\"subtitle\":\"L'équipe derrière la curation\"}},\"events\":{\"title\":\"Le Pouls\",\"subtitle\":\"Événements \u0026 Production\",\"tagline\":\"Nous n'organisons pas d'événements ; nous concevons des étapes culturelles.\",\"description\":\"Nos productions se définissent par la convergence d'une direction artistique électronique de classe mondiale, d'une technologie multimédia de pointe et d'environnements intimistes et soignés. En intégrant des architectures sonores de haute performance et des expériences visuelles immersives, nous concevons des atmosphères aussi profondes qu'électrisantes. Qu'il s'agisse d'un speakeasy souterrain ou d'une odyssée en plein air, nos événements s'adressent à un public exigeant en quête d'un divertissement sensoriel d'avant-garde.\",\"experience\":\"L'Expérience : Sur mesure. Immersive. Inoubliable.\",\"shukshuta\":{\"title\":\"Shukshuta Speakeasy\",\"body\":\"Notre série intime signature.\"},\"upcoming\":\"À venir\",\"past\":\"Événements passés\",\"services\":{\"title\":\"Ce que nous faisons\",\"items\":[\"Production de festivals\",\"Stratégie événementielle\",\"Expériences sur mesure\",\"Activations de marque\"]}},\"trading\":{\"title\":\"La Collection\",\"subtitle\":\"Automobile de Luxe \u0026 Vintage\",\"tagline\":\"Le vrai luxe est intemporel.\",\"body\":\"Notre division d'importation est dédiée exclusivement à l'approvisionnement d'actifs automobiles de grande valeur. Nous sélectionnons un portefeuille spécialisé reliant des véhicules de luxe modernes d'élite à des classiques vintage méticuleusement restaurés. Nous n'importons pas simplement des moyens de transport ; nous sourçons le patrimoine automobile, l'excellence en ingénierie et des œuvres d'art roulantes pour le collectionneur d'élite et le connaisseur moderne.\",\"standard\":\"Le Standard : Patrimoine. Performance. Prestige.\",\"categories\":{\"all\":\"Tous\",\"modern\":\"Luxe Moderne\",\"vintage\":\"Classique Vintage\"},\"specs\":\"Spécifications\",\"history\":\"Provenance\",\"inquire\":\"Demander une consultation\"},\"realEstate\":{\"title\":\"Le Sanctuaire\",\"subtitle\":\"Immobilier \u0026 Développement\",\"tagline\":\"Concevoir l'avenir de l'hospitalité.\",\"vision\":\"Nous faisons évoluer le paysage des loisirs. Nos futurs projets sont un dialogue entre l'innovation architecturale et la beauté sauvage de l'Éthiopie. Des retraites de montagne de luxe aux sanctuaires nichés au cœur des forêts, nous concevons des espaces qui transcendent l'hébergement traditionnel, offrant un sens profond du lieu dans un monde de plus en plus éphémère.\",\"future\":\"L'Avenir : Durable. Visionnaire. Éternel.\",\"pipeline\":\"Pipeline de projets\",\"philosophy\":{\"title\":\"Philosophie de design\",\"body\":\"Éthos de luxe durable.\"},\"investment\":{\"title\":\"Thèse d'investissement\",\"body\":\"Une fenêtre unique pour l'investissement hôtelier visionnaire.\"},\"onDemand\":{\"title\":\"Commandes sur mesure\",\"body\":\"Vous avez un terrain ? Nous construisons.\"},\"explore\":\"Explorer l'investissement\"},\"gallery\":{\"title\":\"Portfolio\",\"subtitle\":\"Un voyage visuel\",\"filter\":{\"all\":\"Tous\",\"events\":\"Événements\",\"collection\":\"Collection\",\"sanctuary\":\"Sanctuaire\"}},\"partners\":{\"title\":\"Partenaires\",\"subtitle\":\"Approuvé par les meilleurs\",\"strategic\":\"Partenaires stratégiques\",\"cultural\":\"Partenaires culturels et médias\",\"featured\":\"Partenaire à la une\"},\"contact\":{\"title\":\"Construisons l'avenir ensemble\",\"subtitle\":\"Groovethiopia s'engage à cultiver des partenariats à long terme.\",\"paths\":{\"events\":\"Événements \u0026 Production\",\"eventsDesc\":\"Partenariats de festivals, activations\",\"trading\":\"Commerce \u0026 Import-Export\",\"tradingDesc\":\"Approvisionnement automobile\",\"realEstate\":\"Immobilier \u0026 Développement\",\"realEstateDesc\":\"Investissement, partenariats\"},\"form\":{\"name\":\"Nom / Organisation\",\"email\":\"Email\",\"phone\":\"Téléphone\",\"division\":\"Nature de la demande\",\"message\":\"Détails du projet\",\"submit\":\"Envoyer\",\"signIn\":\"Connectez-vous avec Google pour envoyer\",\"signInRequired\":\"Vous devez vous connecter avec Google pour envoyer une demande.\"},\"details\":{\"address\":\"Siège\",\"email\":\"Email\",\"phone\":\"Téléphone\",\"hours\":\"Horaires\"}},\"footer\":{\"rights\":\"Tous droits réservés.\",\"explore\":\"Explorer\",\"connect\":\"Connecter\"},\"common\":{\"viewMore\":\"Voir plus\",\"learnMore\":\"En savoir plus\",\"loading\":\"Chargement...\",\"submitting\":\"Envoi...\",\"error\":\"Une erreur est survenue\",\"success\":\"Demande reçue — nous répondrons sous 24 heures.\"}},\"children\":[\"$L98\",\"$L99\",\"$L9a\",\"$L9b\",\"$L9c\"]},\"$95\",\"$96\",1]\n"])</script><script>self.__next_f.push([1,"51:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"},\"$3c\",\"$9d\",0],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"},\"$3c\",\"$9e\",0],[\"$\",\"meta\",\"2\",{\"name\":\"theme-color\",\"content\":\"#0a0a0a\"},\"$3c\",\"$9f\",0]]\n98:[\"$\",\"$La1\",null,{},\"$29\",\"$a0\",1]\na8:D\"$a9\"\n"])</script><script>self.__next_f.push([1,"99:[\"$\",\"main\",null,{\"children\":[\"$\",\"$L15\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$a4\",\"errorStyles\":[\"$\",\"$L7\",null,{\"type\":\"error\",\"pagePath\":\"[locale]