# Caddy reverse proxy + auto SSL via Let's Encrypt

# Public site
groovethiopia.com, www.groovethiopia.com {
    reverse_proxy frontend:3000 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
    }

    encode gzip zstd

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # Cache static assets
    @assets path /_next/static/* /images/* /fonts/*
    header @assets Cache-Control "public, max-age=31536000, immutable"
}

# Admin panel
admin.groovethiopia.com {
    reverse_proxy backend:3001 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
    }

    encode gzip zstd

    # Tighter security for admin
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
    }

    # Rate limit admin auth endpoints
    @auth path /api/auth/*
    rate_limit @auth 10r/m

    # Block robots from indexing admin
    header /robots.txt "Content-Type: text/plain"
    respond /robots.txt "User-agent: *\nDisallow: /\n"
}

# Media subdomain (Cloudflare R2 custom domain)
media.groovethiopia.com {
    reverse_worker https://r2.cloudflarestorage.com {
        header_up Host {http.reverse_proxy.upstream.host}
    }
}

# ----------------------------------------------------------------------
# Preview / staging — served at groovethiopia.livejamgames.com before the
# change is promoted to groovethiopia.com. Same Next.js stack, separate
# DB and env. Brought up via `docker compose --profile staging up -d`.
# ----------------------------------------------------------------------
groovethiopia.livejamgames.com {
    reverse_proxy staging-frontend:3000 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
    }

    encode gzip zstd

    # Same security posture as prod, but no HSTS staging environments should
    # ever pin HSTS — keeps the preview recoverable if certs misfire.
    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # Tell crawlers not to index the preview
    header /robots.txt "Content-Type: text/plain"
    respond /robots.txt "User-agent: *\nDisallow: /\n"

    # Cache busting for static assets
    @assets path /_next/static/*
    header @assets Cache-Control "public, max-age=31536000, immutable"

    # Admin API: route /api/* traffic directly to the staging backend so the
    # preview can independently call public tickets, checkout, etc.
    @api path /api/*
    reverse_proxy @api staging-backend:3001 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
    }
}